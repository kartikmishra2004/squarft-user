{
  "cli": {
    "version": ">= 10.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://api.squarft.com",
        "EXPO_PUBLIC_AI_BASE_URL": "https://ai.squarft.com"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://api.squarft.com",
        "EXPO_PUBLIC_AI_BASE_URL": "https://ai.squarft.com"
      }
    }
  }
}