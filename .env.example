# Backend API Configuration
# Copy this file to .env and update the IP address

# Update this IP address to your machine's local IP when testing on physical device
# To find your IP:
#   Windows: Run 'ipconfig' in Command Prompt, look for "IPv4 Address"
#   Mac/Linux: Run 'ifconfig' in Terminal, look for "inet" under your network interface
#   
# Examples:
#   - Physical device on same WiFi: http://192.168.0.104:3000
#   - Android emulator: http://10.0.2.2:3000
#   - iOS simulator: http://localhost:3000

EXPO_PUBLIC_API_BASE_URL=http://192.168.0.104:3000
