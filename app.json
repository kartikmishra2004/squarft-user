{
  "expo": {
    "name": "squarFT User",
    "slug": "squarft",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icons/app-icon.png",
    "scheme": "squarftuser",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bitcode": false
    },
    "android": {
      "googleServicesFile": "./app/google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.squarft.user",
      "permissions": [
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.CAMERA",
        "android.permission.INTERNET",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.RECORD_AUDIO",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.WAKE_LOCK",
        "android.permission.BLUETOOTH",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "androidNavigationBar": {
      "backgroundColor": "#ffffff",
      "barStyle": "dark-content"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-splash-screen",
        {
          "image": "./assets/icons/icon.png",
          "resizeMode": "cover",
          "imageWidth": 200,
          "backgroundColor": "#4A43EC",
          "dark": {
            "backgroundColor": "#4A43EC"
          }
        }
      ],
      [
        "@livekit/react-native-expo-plugin",
        {
          "android": {
            "audioType": "communication"
          },
          "ios": {
            "enableMultitaskingCameraAccess": false
          }
        }
      ],
      [
        "@config-plugins/react-native-webrtc",
        {
          "microphonePermission": "Allow SquarFT to use your microphone for AI voice calls."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow SquarFT to use your location to show nearby projects."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow SquarFT to use Face ID to unlock the app."
        }
      ],
      "expo-font"
    ],
    "splash": {
      "image": "./assets/icons/icon.png",
      "resizeMode": "cover",
      "imageWidth": 200,
      "backgroundColor": "#4A43EC",
      "dark": {
        "backgroundColor": "#4A43EC"
      }
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d20cc294-6ce2-4113-863b-c2fa6eeb07b9"
      }
    }
  }
}
